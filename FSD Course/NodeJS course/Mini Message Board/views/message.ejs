<%- include('partials/header') %>

<section class="page-header">
  <h1><%= title %></h1>
  <a href="/" class="back-link">← Back to messages</a>
</section>

<section class="message-detail">
  <div class="detail-card">
    <div class="detail-meta">
      <span class="avatar avatar-lg"><%= message.user.charAt(0).toUpperCase() %></span>
      <div>
        <strong class="detail-user"><%= message.user %></strong>
        <time class="detail-date">
          <%= message.added.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %>
          &nbsp;at&nbsp;
          <%= message.added.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
        </time>
      </div>
    </div>
    <div class="detail-divider"></div>
    <p class="detail-text"><%= message.text %></p>
  </div>
</section>

<%- include('partials/footer') %>
