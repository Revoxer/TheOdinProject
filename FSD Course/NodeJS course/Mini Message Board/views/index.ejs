<%- include('partials/header') %>

<section class="page-header">
  <h1><%= title %></h1>
  <span class="count"><%= messages.length %> message<%= messages.length !== 1 ? 's' : '' %></span>
</section>

<section class="messages">
  <% if (messages.length === 0) { %>
    <div class="empty">
      <p>No messages yet. <a href="/new">Be the first!</a></p>
    </div>
  <% } else { %>
    <% messages.slice().reverse().forEach(function(message) { %>
      <article class="message-card">
        <div class="message-meta">
          <span class="message-user">
            <span class="avatar"><%= message.user.charAt(0).toUpperCase() %></span>
            <%= message.user %>
          </span>
          <time class="message-date">
            <%= message.added.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
            &nbsp;·&nbsp;
            <%= message.added.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
          </time>
        </div>
        <p class="message-text"><%= message.text %></p>
        <div class="message-actions">
          <a href="/messages/<%= message.id %>" class="btn-open">Open →</a>
        </div>
      </article>
    <% }); %>
  <% } %>
</section>

<%- include('partials/footer') %>
