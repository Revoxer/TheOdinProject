<%- include('../partials/header', { title: 'New Category', currentPath: '/categories' }) %>

<div class="breadcrumb">
  <a href="/categories">Categories</a>
  <span>/</span>
  <span>New</span>
</div>

<div class="page-header">
  <div>
    <h1>New Category</h1>
  </div>
</div>

<div class="form-wrap">
  <form method="POST" action="/categories">

    <div class="form-group">
      <label for="name">Category Name *</label>
      <input type="text" id="name" name="name" placeholder="e.g. Electronics" required autofocus>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" placeholder="Short category description…"></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create category</button>
      <a href="/categories" class="btn btn-ghost">Cancel</a>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>